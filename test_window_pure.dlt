# Pure Dolet Window Library Integration Test
# Tests window creation, event loop, and cleanup without C runtime dependencies
# Uses Input Library for keyboard detection (ESC to close)
# Requirements: 6.1, 6.2, 6.3, 6.4, 6.5

import window
#import input

# ====================================
# Main Program
# ====================================

# Create window using the library
title = "Pure Dolet Window Test"
win: Window = Window.create(title, 800, 600)

if win.handle != 0:

    
    # Get window dimensions to verify
    w: i32 = win.get_width()
    h: i32 = win.get_height()

    #while win.should_close() == 0 and frame_count < max_frames:
    while win.should_close() == false:
        # Poll events (handles window messages)
        #win.poll_events()
        win.wait_events_timeout(16)
        
        # Use Input Library for ESC key detection
        # KEY_ESCAPE = 27 (from input library)
        #if Input.is_key_pressed(KEY_ESCAPE):
        #    print("ESC pressed - closing window")
        #    break
        
    # Cleanup
    win.destroy()

