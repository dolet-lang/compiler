# Test library methods with new 3-field layout

# Test size()
mylist: list<i32> = [1, 2, 3]
print("initial size:")
print(mylist.size())

# Test append()
mylist.append(4)
mylist.append(5)
print("after append size:")
print(mylist.size())

# Test foreach after append
print("values:")
for v in mylist:
    print(v)

# Test is_empty
print("is_empty:")
print(mylist.is_empty())

# Test clear
mylist.clear()
print("after clear size:")
print(mylist.size())

print("ALL METHODS DONE")
