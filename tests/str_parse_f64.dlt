import std

# parse_f64
print(Convert.f64_to_str(Str.parse_f64("3.14")))            # 3.14
print(Convert.f64_to_str(Str.parse_f64("-0.5")))            # -0.5
print(Convert.f64_to_str(Str.parse_f64("42")))              # 42
print(Convert.f64_to_str(Str.parse_f64("  100.25 ")))       # 100.25
print(Convert.f64_to_str(Str.parse_f64("1.5e2")))           # 150
print(Convert.f64_to_str(Str.parse_f64("2.5E-1")))          # 0.25
print(Convert.f64_to_str(Str.parse_f64("xyz")))             # 0

# parse_i32
print(Convert.i32_to_str(Str.parse_i32("42")))              # 42
print(Convert.i32_to_str(Str.parse_i32("-7")))              # -7

# Method form
n: f64 = "2.5".parse_f64()
print(Convert.f64_to_str(n))                                # 2.5

# is_empty
print(Convert.bool_to_str("".is_empty()))                   # true
print(Convert.bool_to_str("hi".is_empty()))                 # false

# Chained
empty_after_trim: bool = "   ".trim().is_empty()
print(Convert.bool_to_str(empty_after_trim))                # true
