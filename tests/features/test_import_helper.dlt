import std

import kubic.core    [App, SceneTree, Node]
import kubic.node3d  [Node3D, Camera3D, Light3D]
import kubic.node2d  [Node2D, Sprite2D]
import kubic.physics [RigidBody3D, CollisionShape3D]
import kubic.input   [Input, KeyCode]
import kubic.render  [Vulkan, Window, Viewport]
import aecs          [component, system, resource, query]

#===============================================#
# كل node بتعرّفها كـ struct وراثتها من node أساسي
@[node]
struct GameScene extends SceneTree:

    # الـ root node
    world = Node3D.new(name="World")

    # Camera كـ child من World
    camera = Camera3D.new(name="MainCamera")
        .set_pos(x=0.0, y=5.0, z=10.0)
        .look_at(0.0, 0.0, 0.0)
        .set_fov(75.0)

    # Player node
    player = Node3D.new(name="Player")
        .set_pos(x=0.0, y=0.0, z=0.0)
        .add_child(
            Sprite2D.new(name="PlayerSprite")
                .set_texture("assets/player.png")
        )
        .add_child(
            RigidBody3D.new(name="PlayerBody")
                .set_mass(1.0)
                .add_child(
                    CollisionShape3D.new()
                        .set_shape(BoxShape(1.0, 1.0, 1.0))
                        .set_scale(1.0, 2.0, 1.0)
                )
        )

    # Light
    sun = Light3D.new(name="Sun")
        .set_type("directional")
        .set_color(1.0, 0.95, 0.8)
        .set_intensity(1.2)
        .set_rotation(x=-45.0, y=30.0, z=0.0)
        .set_shadow(true)
        .set_shadow_resolution(2048)
        .set_shadow_bias(0.005)
        .set_shadow_normal_bias(0.1)
        .set_shadow_cascades(4)


    # بناء الـ Tree
    fun build() -> void:
        world
            .add_child(camera)
            .add_child(player)
            .add_child(sun)
        
        self.set_root(world)
#===============================================#

import kubic.core   [Node3D, delta_time]
import kubic.input  [Input, KeyCode]
import aecs         [component, system, query, resource]

# === Components ===
@[component]
struct PlayerController:
    speed: f32
        default: 5.0
    jump_force: f32
        default=8.0

@[component]
struct Grounded:
    value: bool
        default: false

# === Movement System ===
@[system(stage="update")]
fun player_movement(
    node: @query<Node3D, has=PlayerController>,
    ctrl: @query<PlayerController>,
    grounded: @query<Grounded>,
    dt: @res<DeltaTime>
) -> void:

    vel = Vec3(0.0, 0.0, 0.0)

    if Input.held(KeyCode.W):
        vel.z -= ctrl.speed * dt.value
    if Input.held(KeyCode.S):
        vel.z += ctrl.speed * dt.value
    if Input.held(KeyCode.A):
        vel.x -= ctrl.speed * dt.value
    if Input.held(KeyCode.D):
        vel.x += ctrl.speed * dt.value

    if Input.pressed(KeyCode.Space) and grounded.value:
        vel.y += ctrl.jump_force

    node.translate(vel)

# === Camera Follow System ===
@[system(stage="update", after="player_movement")]
fun camera_follow(
    cam: @query<Camera3D>,
    player: @query<Node3D, has=PlayerController>,
    dt: @res<DeltaTime>
) -> void:
    target = player.get_pos() + Vec3(0.0, 5.0, 10.0)
    cam.set_pos(
        Vec3.lerp(cam.get_pos(), target, 5.0 * dt.value)
    )
#===============================================#

import kubic.render [Vulkan, Window, RenderPipeline]

@[resource]
struct RenderConfig:
    width: i32
        default: 1920
    height: i32
        default: 1080
    title: str
        default: "Kubic Game"
    vsync: bool
        default: true
    msaa: i32
        valid_values: [1, 2, 4, 8]
        default: 4

@[system(stage="startup")]
fun init_renderer(config: @res<RenderConfig>) -> void:

    window = Window.new()
        .set_size(config.width, config.height)
        .set_title(config.title)
        .set_vsync(config.vsync)
        .build()

    vulkan = Vulkan.new()
        .set_window(window)
        .set_msaa(config.msaa)
        .enable_validation(debug=true)
        .build()

    pipeline = RenderPipeline.new()
        .set_backend(vulkan)
        .add_pass("geometry")
        .add_pass("lighting")
        .add_pass("post_process")
        .build()
#===============================================#

@[plugin]
struct KubicDefaultPlugins:
    fun build(app: App) -> void:
        app
            .add_plugin(WindowPlugin)
            .add_plugin(VulkanPlugin)
            .add_plugin(PhysicsPlugin)
            .add_plugin(InputPlugin)
            .add_plugin(AudioPlugin)
            .add_plugin(AECSPlugin)

@[plugin]
struct PhysicsPlugin:
    gravity: Vec3
        default: Vec3(0.0, -9.8, 0.0)
    
    fun build(app: App) -> void:
        app
            .add_resource(PhysicsWorld(gravity: self.gravity))
            .add_system(physics_step)
            .add_system(collision_detection)
            .add_system(collision_response)
#===============================================#

import kubic.core   [App]
import kubic.render [KubicDefaultPlugins]

fun main() -> void:
    App.new()
        .set_config(RenderConfig(
            width: 1920,
            height: 1080,
            title: "My Kubic Game",
            msaa: 4
        ))
        .add_plugin(KubicDefaultPlugins)
        .add_scene(GameScene)
        .add_system(player_movement)
        .add_system(camera_follow)
        .add_system(enemy_ai_system)
        .run()

