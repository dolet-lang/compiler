fun mk_map_entry(key: i64, value: i64) -> i64:
    n: i64 = alloc_node(NODE_MAP_ENTRY)
    Memory.write_i64(n + 8, key)
    Memory.write_i64(n + 16, value)
    return n

fun mentry_key(n: i64) -> i64:
    return Memory.read_i64(n + 8)

fun mentry_value(n: i64) -> i64:
    return Memory.read_i64(n + 16)

# ==========================================
# Module System Nodes
# ==========================================

# ImportNode: f0=module_name (str), f1=alias (str, 0), f2=selected_symbols (node_list, 0), f3=import_type (i64)
fun mk_import(mod_name: str, alias: str, symbols: i64, imp_type: i64) -> i64:
    n: i64 = alloc_node(NODE_IMPORT)
    Memory.write_i64(n + 8, mod_name as i64)
    Memory.write_i64(n + 16, alias as i64)
    Memory.write_i64(n + 24, symbols)
    Memory.write_i64(n + 32, imp_type)
    return n

fun import_module(n: i64) -> str:
    return Memory.read_i64(n + 8) as str

fun import_alias(n: i64) -> str:
    return Memory.read_i64(n + 16) as str

fun import_symbols(n: i64) -> i64:
    return Memory.read_i64(n + 24)

fun import_itype(n: i64) -> i64:
    return Memory.read_i64(n + 32)

# NamespaceAccessNode: f0=namespace (str), f1=symbol (str)
fun mk_ns_access(ns: str, symbol: str) -> i64:
    n: i64 = alloc_node(NODE_NS_ACCESS)
    Memory.write_i64(n + 8, ns as i64)
    Memory.write_i64(n + 16, symbol as i64)
    return n

fun nsaccess_ns(n: i64) -> str:
    return Memory.read_i64(n + 8) as str

fun nsaccess_symbol(n: i64) -> str:
    return Memory.read_i64(n + 16) as str

# NamespacedStructInstantiationNode: f0=namespace (str), f1=struct_name (str),
#                                     f2=field_values (node_list), f3=type_args (node_list, 0)
fun mk_ns_struct_inst(ns: str, sname: str, field_vals: i64, type_args: i64) -> i64:
    n: i64 = alloc_node(NODE_NS_STRUCT_INST)
    Memory.write_i64(n + 8, ns as i64)
    Memory.write_i64(n + 16, sname as i64)
    Memory.write_i64(n + 24, field_vals)
    Memory.write_i64(n + 32, type_args)
    return n

# NamespacedStaticMethodCallNode: f0=namespace (str), f1=struct_name (str), f2=method (str), f3=args (node_list)
fun mk_ns_static_method(ns: str, sname: str, method: str, args: i64) -> i64:
    n: i64 = alloc_node(NODE_NS_STATIC_METHOD)
    Memory.write_i64(n + 8, ns as i64)
    Memory.write_i64(n + 16, sname as i64)
    Memory.write_i64(n + 24, method as i64)
    Memory.write_i64(n + 32, args)
    return n

# NamespacedFunctionCallNode: f0=namespace (str), f1=function_name (str), f2=args (node_list), f3=type_args (node_list, 0)
fun mk_ns_fun_call(ns: str, fname: str, args: i64, type_args: i64) -> i64:
    n: i64 = alloc_node(NODE_NS_FUN_CALL)
    Memory.write_i64(n + 8, ns as i64)
    Memory.write_i64(n + 16, fname as i64)
    Memory.write_i64(n + 24, args)
    Memory.write_i64(n + 32, type_args)
    return n

# ==========================================
# Trait Nodes
# ==========================================

# TraitDeclNode: f0=name (str), f1=methods (node_list), f2=type_params (node_list, 0)
fun mk_trait_decl(name: str, methods: i64, type_params: i64) -> i64:
    n: i64 = alloc_node(NODE_TRAIT_DECL)
    Memory.write_i64(n + 8, name as i64)
    Memory.write_i64(n + 16, methods)
    Memory.write_i64(n + 24, type_params)
    return n

fun tdecl_name(n: i64) -> str:
    return Memory.read_i64(n + 8) as str

fun tdecl_methods(n: i64) -> i64:
    return Memory.read_i64(n + 16)

# TraitMethodSignature: f0=name (str), f1=params (node_list), f2=return_type (str, 0)
fun mk_trait_method_sig(name: str, params: i64, ret_type: str) -> i64:
    n: i64 = alloc_node(NODE_TRAIT_METHOD_SIG)
    Memory.write_i64(n + 8, name as i64)
    Memory.write_i64(n + 16, params)
    Memory.write_i64(n + 24, ret_type as i64)
    return n

fun tmsig_name(n: i64) -> str:
    return Memory.read_i64(n + 8) as str

fun tmsig_params(n: i64) -> i64:
    return Memory.read_i64(n + 16)

fun tmsig_ret_type(n: i64) -> str:
    return Memory.read_i64(n + 24) as str

# ==========================================
# Misc Nodes
# ==========================================

# ExtendBlockNode: f0=type_name (str), f1=methods (node_list)
fun mk_extend_block(tname: str, methods: i64) -> i64:
    n: i64 = alloc_node(NODE_EXTEND_BLOCK)
    Memory.write_i64(n + 8, tname as i64)
    Memory.write_i64(n + 16, methods)
    return n

fun extend_tname(n: i64) -> str:
    return Memory.read_i64(n + 8) as str

fun extend_methods(n: i64) -> i64:
    return Memory.read_i64(n + 16)

# CodeBlockPlaceholderNode: f0=params (node_list, 0)
fun mk_code_block_ph(params: i64) -> i64:
    n: i64 = alloc_node(NODE_CODE_BLOCK_PH)
    Memory.write_i64(n + 8, params)
    return n

# TypeAliasNode: f0=name (str), f1=target_type (i64 — str or FunPtrType node)
fun mk_type_alias(name: str, target: i64) -> i64:
    n: i64 = alloc_node(NODE_TYPE_ALIAS)
    Memory.write_i64(n + 8, name as i64)
    Memory.write_i64(n + 16, target)
    return n

fun talias_name(n: i64) -> str:
    return Memory.read_i64(n + 8) as str

fun talias_target(n: i64) -> i64:
    return Memory.read_i64(n + 16)

# FunctionPointerType: f0=param_types (node_list of str ptrs), f1=return_type (str, 0)
fun mk_fun_ptr_type(param_types: i64, ret_type: str) -> i64:
    n: i64 = alloc_node(NODE_FUN_PTR_TYPE)
    Memory.write_i64(n + 8, param_types)
    Memory.write_i64(n + 16, ret_type as i64)
    return n

fun fptr_params(n: i64) -> i64:
    return Memory.read_i64(n + 8)

fun fptr_ret_type(n: i64) -> str:
    return Memory.read_i64(n + 16) as str

# IsNullNode: f0=value (node)
fun mk_is_null(value: i64) -> i64:
    n: i64 = alloc_node(NODE_IS_NULL)
    Memory.write_i64(n + 8, value)
    return n

fun isnull_value(n: i64) -> i64:
    return Memory.read_i64(n + 8)

# IsNotNullNode: f0=value (node)
fun mk_is_not_null(value: i64) -> i64:
    n: i64 = alloc_node(NODE_IS_NOT_NULL)
    Memory.write_i64(n + 8, value)
    return n

fun isnotnull_value(n: i64) -> i64:
    return Memory.read_i64(n + 8)
