fun ctxblock_body(n: i64) -> i64:
    return Memory.read_i64(n + 24)

# ==========================================
# Struct Nodes
# ==========================================

# StructField: f0=name (str), f1=field_type (str, 0 if inferred), f2=nullable (0/1),
#              f3=default_value (node, 0 if none), f4=access_modifier (str), f5=is_static (0/1)
fun mk_struct_field(name: str, ftype: str, nullable: i64, default_val: i64, access: str, is_static: i64) -> i64:
    n: i64 = alloc_node(NODE_STRUCT_FIELD)
    Memory.write_i64(n + 8, name as i64)
    Memory.write_i64(n + 16, ftype as i64)
    Memory.write_i64(n + 24, nullable)
    Memory.write_i64(n + 32, default_val)
    Memory.write_i64(n + 40, access as i64)
    Memory.write_i64(n + 48, is_static)
    return n

fun sfield_name(n: i64) -> str:
    return Memory.read_i64(n + 8) as str

fun sfield_type(n: i64) -> str:
    return Memory.read_i64(n + 16) as str

fun sfield_nullable(n: i64) -> i64:
    return Memory.read_i64(n + 24)

fun sfield_default(n: i64) -> i64:
    return Memory.read_i64(n + 32)

fun sfield_access(n: i64) -> str:
    return Memory.read_i64(n + 40) as str

fun sfield_is_static(n: i64) -> i64:
    return Memory.read_i64(n + 48)

# StructDeclNode: f0=name (str), f1=fields (node_list), f2=type_params (node_list, 0),
#                 f3=base_class (str, 0), f4=methods (node_list, 0),
#                 f5=is_abstract (0/1), f6=stack_allocated (0/1), f7=parent_structs (node_list, 0)
fun mk_struct_decl(name: str, fields: i64, type_params: i64, base_class: str, methods: i64, is_abstract: i64, stack_alloc: i64, parents: i64) -> i64:
    n: i64 = alloc_node(NODE_STRUCT_DECL)
    Memory.write_i64(n + 8, name as i64)
    Memory.write_i64(n + 16, fields)
    Memory.write_i64(n + 24, type_params)
    Memory.write_i64(n + 32, base_class as i64)
    Memory.write_i64(n + 40, methods)
    Memory.write_i64(n + 48, is_abstract)
    Memory.write_i64(n + 56, stack_alloc)
    Memory.write_i64(n + 64, parents)
    return n

fun sdecl_name(n: i64) -> str:
    return Memory.read_i64(n + 8) as str

fun sdecl_fields(n: i64) -> i64:
    return Memory.read_i64(n + 16)

fun sdecl_type_params(n: i64) -> i64:
    return Memory.read_i64(n + 24)

fun sdecl_base_class(n: i64) -> str:
    return Memory.read_i64(n + 32) as str

fun sdecl_methods(n: i64) -> i64:
    return Memory.read_i64(n + 40)

fun sdecl_parents(n: i64) -> i64:
    return Memory.read_i64(n + 64)

# StructInstantiationNode: f0=struct_name (str), f1=field_values (node_list of FieldValNode), f2=type_args (node_list, 0)
fun mk_struct_inst(name: str, field_vals: i64, type_args: i64) -> i64:
    n: i64 = alloc_node(NODE_STRUCT_INST)
    Memory.write_i64(n + 8, name as i64)
    Memory.write_i64(n + 16, field_vals)
    Memory.write_i64(n + 24, type_args)
    return n

