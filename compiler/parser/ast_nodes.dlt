# MethodDefNode: f0=name (str), f1=params (node_list), f2=return_type (str, 0 if void),
#                f3=body (node_list), f4=is_static (0/1), f5=access_modifier (str),
#                f6=is_abstract (0/1), f7=is_async (0/1)
fun mk_method_def(name: str, params: i64, ret_type: str, body: i64, is_static: i64, access: str, is_abstract: i64, is_async: i64) -> i64:
