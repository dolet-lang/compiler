# Raylib Module Metadata
# Simple and easy-to-use library for videogames and GUI programming

[info]
name = raylib
version = 5.0
description = A simple and easy-to-use library to enjoy videogames programming
url = https://www.raylib.com

[libs]
# Import libraries for linking (.lib or .a files)
# Note: raylib.lib includes both raylib and raygui
windows = raylib.lib
linux = libraylib.so
macos = libraylib.dylib

[dlls]
# Runtime libraries to copy (.dll or .so files)
windows = raylib.dll, raygui.dll
linux = libraylib.so
macos = libraylib.dylib

[dependencies]
# No external dependencies - raylib is self-contained!
