# ===== Helper Structs =====
struct Rectangle:
    x: f32 = 0.0
    y: f32 = 0.0
    width: f32 = 0.0
    height: f32 = 0.0

struct Vector2:
    x: f32 = 0.0
    y: f32 = 0.0

struct Color:
    r: u8 = 255
    g: u8 = 255
    b: u8 = 255
    a: u8 = 255


# ===== Helper Functions =====
fun rect(x: f32, y: f32, width: f32, height: f32) -> Rectangle:
    r: Rectangle = Rectangle()
    r.x = x
    r.y = y
    r.width = width
    r.height = height
    return r

fun vec2(x: f32, y: f32) -> Vector2:
    v: Vector2 = Vector2()
    v.x = x
    v.y = y
    return v
