    0x12, 0x00, 0x00, 0x00, 0xFD, 0x00, 0x01, 0x00, 0x38, 0x00, 0x01, 0x00
]

# Shader sizes
const GENERIC_VERT_SHADER_SIZE: i64 = 1304
const GENERIC_FRAG_SHADER_SIZE: i64 = 572

# Helper struct to hold shader data
struct EmbeddedShader:
    data: i64 = 0
    size: i64 = 0

# Get embedded vertex shader
# Returns pointer to shader data and size
# Caller must NOT free the returned pointer (it's static data)
fun get_generic_vert_shader() -> EmbeddedShader:
    shader: EmbeddedShader = EmbeddedShader()
    # Combine both parts into contiguous memory
    shader.size = GENERIC_VERT_SHADER_SIZE
    shader.data = Memory.malloc_zeroed(shader.size)
    if shader.data != 0:
        # Copy first part (800 bytes)
        i: i32 = 0
        while i < 800:
            byte_val: u8 = GENERIC_VERT_SHADER[i]
            Memory.write_i8(shader.data + i, byte_val as i8)
            i = i + 1
        # Copy second part (504 bytes)
        j: i32 = 0
        while j < 504:
            byte_val2: u8 = GENERIC_VERT_SHADER_PART2[j]
            Memory.write_i8(shader.data + 800 + j, byte_val2 as i8)
            j = j + 1
    return shader

# Get embedded fragment shader
# Returns pointer to shader data and size
# Caller must NOT free the returned pointer (it's static data)
fun get_generic_frag_shader() -> EmbeddedShader:
    shader: EmbeddedShader = EmbeddedShader()
    shader.size = GENERIC_FRAG_SHADER_SIZE
    shader.data = Memory.malloc_zeroed(shader.size)
    if shader.data != 0:
        i: i32 = 0
        while i < 572:
            byte_val: u8 = GENERIC_FRAG_SHADER[i]
            Memory.write_i8(shader.data + i, byte_val as i8)
            i = i + 1
    return shader
